FROM node:18

ARG BASE_PATH
ARG APP_DOMAIN
ARG EDGE_CONFIG_ID_WITH_MEDIA
ARG ORGANIZATION_ID

ENV BASE_PATH=$BASE_PATH
ENV APP_DOMAIN=$APP_DOMAIN
ENV EDGE_CONFIG_ID_WITH_MEDIA=$EDGE_CONFIG_ID_WITH_MEDIA
ENV ORGANIZATION_ID=$ORGANIZATION_ID

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

RUN npm run build

EXPOSE 443

CMD ["npm", "start"]