FROM node:18

ARG BASE_PATH
ARG APP_DOMAIN
ARG AEP_EDGE_DOMAIN
ARG EDGE_CONFIG_ID_WITH_ANALYTICS
ARG ORGANIZATION_ID
ARG DEMO_SURFACE_NAME
ARG DEMO_SURFACE_URI

ENV BASE_PATH=$BASE_PATH
ENV APP_DOMAIN=$APP_DOMAIN
ENV AEP_EDGE_DOMAIN=$AEP_EDGE_DOMAIN
ENV EDGE_CONFIG_ID_WITH_ANALYTICS=$EDGE_CONFIG_ID_WITH_ANALYTICS
ENV ORGANIZATION_ID=$ORGANIZATION_ID
ENV DEMO_SURFACE_NAME=$DEMO_SURFACE_NAME
ENV DEMO_SURFACE_URI=$DEMO_SURFACE_URI

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

EXPOSE 443

CMD ["npm", "start"]